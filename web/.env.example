# ---- BSale API wrapper (Render) ----
NEXT_PUBLIC_API_URL=https://boykot-api.onrender.com
NEXT_PUBLIC_SITE_URL=https://boykot.cl

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- BSale webhooks ----
# Configure in BSale admin: POST https://boykot.cl/api/webhooks/bsale?token=$BSALE_WEBHOOK_TOKEN
BSALE_WEBHOOK_TOKEN=long-random-string-here
BSALE_CPN_ID=1234

# ---- Brevo (abandoned cart emails + transactional) ----
BREVO_API_KEY=xkeysib-...
EMAIL_FROM_ADDRESS=hola@boykot.cl
EMAIL_FROM_NAME=Boykot

# ---- Vercel Cron auth ----
CRON_SECRET=another-long-random-string

# ---- Cloudflare R2 (color image storage) ----
# Used by scripts/upload-to-r2.js. Only the public base URL is needed at runtime
# by the web app (when we migrate <img src=...> away from Drive).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=boykot-colors
R2_PUBLIC_BASE=https://colors.boykot.cl
